# Copy to .env and fill in (do not commit .env).
# Flask loads this file automatically from the backend folder (python-dotenv).

# OUTDATED: switched to mysql
# Supabase: Project Settings → Database → Connection string (URI)
# Prefer Session mode or Transaction pooler URI from the dashboard.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Flask JWT signing (use a long random string in production)
SECRET_KEY=change-me-to-a-long-random-string

# MYSQL CONFIG
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=studysmash
AUTO_INIT_DB=1
PORT=5050
